# Base dependencies
/node_modules
/.pnp
.pnp.js

# Next.js build output
/.next/
/out/

# Production build artifacts
/build

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment variables (CRITICAL: Never commit your secrets!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Prisma specific (If you generate SQLite DB locally or have schema backups)
/prisma/*.db
/prisma/*.db-journal

# VS Code specific settings (Optional, but recommended)
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
.DS_Store
Thumbs.db